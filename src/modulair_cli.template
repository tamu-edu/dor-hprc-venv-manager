import json
import subprocess
import argparse
import re
import getpass
import datetime
import signal

from utils import (
    get_user,
    get_user_metaloc,
    get_group_metaloc,
    get_user_groups,
    load_user_metadata,
    load_group_metadata,
    load_all_metadata,
    find_environment_by_name,
    get_environment_path,
    get_metadata_file_path,
    update_metadata_file,
    remove_environment_from_metadata,
    get_py_versions,
    extract_python_version_from_toolchain,
    check_group,
    get_terminal_width,
    truncate_text,
